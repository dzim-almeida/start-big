{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-exists",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "erp-api",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}