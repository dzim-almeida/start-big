# 1. Arquivos e Pastas de Ambiente Virtual
# Ignora a pasta de ambiente virtual
venv/
.venv/

# 2. Python Bytecode e Cache
# Ignora o cache de bytecode (arquivos .pyc e a pasta __pycache__)
__pycache__/
*.pyc
*.pyo
*.pyd

# 3. Arquivos de Banco de Dados Local e Logs
# Ignora seu arquivo de banco de dados SQLite local
*.db
*.sqlite
pdv.db

# 4. Configurações de IDE e Outros Temporários
# Ignora o arquivo .env (crucial para segredos como a SECRET_KEY)
.env
# Arquivos de configurações do VS Code (opcional)
.vscode/

# 5. Ignorar caches de testes (como os arquivos .cpython-313.pyc do Pytest)
# Isso deve ser coberto por *.pyc e __pycache__
.pytest_cache/
backend-fastapi/pdv.db
backend-fastapi/nota.txt
/.claude
/.github
/node_modules

# 6. Ignorar arquivos e pastas relacionados a migrações e estáticos
/backend-fastapi/dist/
/backend-fastapi/build
/backend-fastapi/static
# Migrations Alembic são versionadas (viajam com o código p/ atualizar o banco).
# Apenas os caches são ignorados.
/backend-fastapi/alembic/__pycache__/
/backend-fastapi/alembic/versions/__pycache__/
seeds/
/backend-fastapi/run.py
/backend-fastapi/run.spec
/frontend/src-tauri/binaries
*.pfx
